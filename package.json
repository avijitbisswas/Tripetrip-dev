{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run start:dev",
    "dev:worker": "npm --workspace apps/worker run start:dev",
    "build": "npm run build:packages && npm run build:web && npm run build:api && npm run build:api-worker && npm run build:worker",
    "build:web": "npm --workspace apps/web run build",
    "build:api": "npm --workspace apps/api run build",
    "build:api-worker": "tsc --project apps/api-worker/tsconfig.json",
    "build:worker": "npm --workspace apps/worker run build",
    "build:packages": "npm --workspace @tripetrip/api-contracts run build && npm --workspace @tripetrip/constants run build && npm --workspace @tripetrip/database run build && npm --workspace @tripetrip/observability run build && npm --workspace @tripetrip/security run build && npm --workspace @tripetrip/types run build && npm --workspace @tripetrip/validators run build",
    "build:cloudflare": "cd apps/web && opennextjs-cloudflare build -c ../../wrangler.jsonc --openNextConfigPath ../../open-next.config.ts",
    "build:pages": "cross-env NEXT_OUTPUT=export npm run build:web",
    "deploy:cloudflare": "npm run build:cloudflare && wrangler deploy",
    "deploy:api": "npm run build:api-worker && wrangler deploy --config wrangler.api.jsonc",
    "deploy:pages": "npm run build:pages && wrangler pages deploy apps/web/out --project-name tripetrip-web",
    "preview:cloudflare": "npm run build:cloudflare && wrangler dev --config wrangler.jsonc",
    "preview:api": "wrangler dev --config wrangler.api.jsonc",
    "preview:pages": "npm run build:pages && wrangler pages dev apps/web/out",
    "start": "npm --workspace apps/web run start",
    "preview": "npm --workspace apps/web run start",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:api": "vitest run",
    "test:e2e": "playwright test"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "postcss": "^8.5.10"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@hookform/resolvers": "^5.2.2",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@tailwindcss/typography": "^0.5.19",
    "axios": "^1.15.1",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^1.14.0",
    "mapbox-gl": "^3.22.0",
    "motion": "^12.23.24",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "razorpay": "^2.9.6",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.73.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "shadcn": "^4.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260528.1",
    "@nestjs/testing": "^11.1.24",
    "@opennextjs/cloudflare": "^1.19.11",
    "@playwright/test": "^1.60.0",
    "@types/express": "^4.17.21",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.95.0"
  }
}
